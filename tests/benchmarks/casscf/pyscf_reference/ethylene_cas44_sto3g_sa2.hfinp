%begin_control
    basis       sto-3g
    calculation energy
    verbosity   normal
    basis_type  cartesian
%end_control

%begin_scf
    scf_type    rhf
    correlation casscf
    use_diis    .true.
    max_cycles	100
    diis_dim    8
    engine      rys
    guess       hcore
    nactele     4
    nactorb     4
    nroots      2
    mcscf_max_iter  150
    mcscf_micro_per_macro  4
    tol_mcscf_energy  1e-8
    tol_mcscf_grad    1e-5
%end_scf

%begin_geom
    coord_type  cartesian
    coord_units angstrom
    use_symm    .true.
%end_geom

%begin_coords
6
0   1
C    0.000000    0.000000    0.000000
C    0.000000    0.000000    1.340000
H    0.920000    0.000000   -0.540000
H   -0.920000    0.000000   -0.540000
H    0.000000    0.920000    1.880000
H    0.000000   -0.920000    1.880000
%end_coords
