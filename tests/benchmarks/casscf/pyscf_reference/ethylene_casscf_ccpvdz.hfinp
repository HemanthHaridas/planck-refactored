%begin_control
    basis       cc-pvdz
    calculation energy
    verbosity   normal
    basis_type  cartesian
%end_control

%begin_scf
    scf_type    	rhf
    correlation 	casscf
    use_diis    	.true.
    diis_dim    	8
    engine      	os
    guess       	hcore
    mcscf_max_iter      200
    nactele     	2
    nactorb     	2
    nroots      	1
%end_scf

%begin_geom
    coord_type  cartesian
    coord_units angstrom
    use_symm    .true.
    opt_coords  internal
%end_geom

