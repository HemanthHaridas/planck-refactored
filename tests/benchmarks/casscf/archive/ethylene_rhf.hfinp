%begin_control
    basis       cc-pvdz
    calculation energy
    verbosity   normal
    basis_type  cartesian
%end_control

%begin_scf
    scf_type            rhf
    use_diis            .true.
    diis_dim            8
    engine              os
    guess	        density
    nactele             4
    nactorb             4
    max_cycles		100
    mcscf_max_iter      200
    mcscf_micro_per_macro  4
    tol_mcscf_energy    1e-8
    tol_mcscf_grad      1e-5
%end_scf

%begin_geom
    coord_type  cartesian
    coord_units angstrom
    use_symm    .true.
%end_geom

