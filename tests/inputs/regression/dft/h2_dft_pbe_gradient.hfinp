%begin_control
    basis       sto-3g
    calculation gradient
    verbosity   normal
    basis_type  cartesian
%end_control

%begin_scf
    scf_type    rhf
    use_diis    .true.
    diis_dim    6
    engine      os
    guess       hcore
    max_cycles  50
    tol_energy  1.0e-10
    tol_density 1.0e-10
%end_scf

%begin_dft
    grid                fine
    exchange            pbe
    correlation         pbe
    print_grid_summary  .false.
%end_dft

%begin_geom
    coord_type  cartesian
    coord_units angstrom
    use_symm    .false.
%end_geom

%begin_coords
2
0   1
H     0.000000     0.000000    -0.450000
H     0.000000     0.000000     0.450000
%end_coords
