%begin_control
    basis       sto-3g
    calculation tddft
    verbosity   normal
    basis_type  cartesian
%end_control

%begin_scf
    scf_type    uhf
    use_diis    .true.
    diis_dim    6
    engine      os
    guess       hcore
    level_shift 0.3
    max_cycles  80
    tol_energy  1.0e-8
    tol_density 1.0e-8
%end_scf

%begin_dft
    grid                coarse
    exchange            pbe
    correlation         pbe
    lr_nstates          3
    lr_spin             spin_conserving
    print_grid_summary  .false.
%end_dft

%begin_geom
    coord_type  cartesian
    coord_units angstrom
    use_symm    .true.
%end_geom

%begin_coords
3
0   3
O     0.000000    0.000000     0.117176
H     0.000000    0.756950    -0.468703
H     0.000000   -0.756950    -0.468703
%end_coords
