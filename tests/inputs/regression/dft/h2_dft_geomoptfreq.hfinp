%begin_control
    basis       sto-3g
    calculation geomoptfreq
    verbosity   normal
    basis_type  cartesian
%end_control

%begin_scf
    scf_type    rhf
    use_diis    .true.
    diis_dim    6
    engine      os
    guess       hcore
    max_cycles  50
    tol_energy  1.0e-8
    tol_density 1.0e-8
%end_scf

%begin_dft
    grid                coarse
    exchange            pbe
    correlation         pbe
    print_grid_summary  .false.
%end_dft

%begin_geom
    coord_type  cartesian
    coord_units angstrom
    use_symm    .false.
    opt_coords  cartesian
%end_geom

%begin_coords
2
0   1
H     0.000000     0.000000    -0.450000
H     0.000000     0.000000     0.450000
%end_coords
