%begin_control
    basis       sto-3g
    calculation gradient
    print_populations .true.
    verbosity   normal
    basis_type  cartesian
%end_control

%begin_scf
    scf_type      uhf
    correlation   ump2
    use_diis      .true.
    diis_dim      8
    engine        os
    level_shift   0.3
    diis_restart  2.0
%end_scf

%begin_geom
    coord_type  cartesian
    coord_units angstrom
    use_symm    .true.
%end_geom

%begin_coords
