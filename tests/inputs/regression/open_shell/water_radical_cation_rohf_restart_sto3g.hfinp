%begin_control
    basis       sto-3g
    calculation energy
    print_populations .true.
    verbosity   normal
    basis_type  cartesian
%end_control

%begin_scf
    scf_type    rohf
    guess       full
    use_diis    .true.
    diis_dim    8
    engine      os
%end_scf

%begin_geom
    coord_type  cartesian
    coord_units angstrom
    use_symm    .true.
%end_geom

