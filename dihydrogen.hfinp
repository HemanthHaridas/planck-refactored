%begin_control
    basis       6-31g
    calculation energy
    verbosity   normal
    basis_type  cartesian
%end_control

%begin_scf
    scf_type    uhf
    correlation rmp2
    use_diis    .true.
    diis_dim    8
    engine      os
    guess       hcore
%end_scf

%begin_geom
    coord_type  cartesian
    coord_units angstrom
    use_symm    .true.
%end_geom

%begin_coords
2
0   3
H    -0.000    -0.000     3.94000000000000000000
H    -0.000    -0.000    -3.94000000000000000000
%end_coords
