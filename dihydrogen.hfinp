%begin_control
    basis       cc-pvdz-unc
    calculation energy
    verbosity   normal
    basis_type  cartesian
%end_control

%begin_scf
    scf_type    rhf
    correlation rmp2
    use_diis    .true.
    diis_dim    8
    engine      os
    guess       read
%end_scf

%begin_geom
    coord_type  cartesian
    coord_units angstrom
    use_symm    .true.
%end_geom

%begin_coords
2
0   1
H    -0.000    -0.000     0.000
H    -0.000    -0.000     0.741
%end_coords
