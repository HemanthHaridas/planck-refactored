%begin_control
    basis       sto-3g
    calculation energy
    verbosity   normal
    basis_type  cartesian
%end_control

%begin_scf
    scf_type        rhf
    correlation     rmp2
    use_diis        .true.
    diis_dim        8
    engine          os
    guess           hcore
    save_checkpoint .false.
%end_scf

%begin_geom
    coord_type  cartesian
    coord_units angstrom
    use_symm    .false.
%end_geom

